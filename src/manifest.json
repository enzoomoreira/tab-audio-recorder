{
  "manifest_version": 3,
  "name": "Tab Audio Recorder",
  "version": "0.1.0",
  "description": "Record audio from browser tabs for sampling",
  "permissions": ["tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background/index.ts"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html"
  }
}
