{
  "name": "tab-audio-recorder",
  "version": "0.1.0",
  "description": "Firefox extension to record browser tab audio for sampling",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "start": "web-ext run --source-dir dist --browser-console",
    "lint:ext": "web-ext lint --source-dir dist",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "VITE_TEST_BRIDGE=true bun run build && vitest run --config vitest.e2e.config.ts"
  },
  "keywords": [
    "firefox",
    "extension",
    "webextension",
    "manifest-v3",
    "audio",
    "recording",
    "tab-audio",
    "mediarecorder"
  ],
  "author": "Enzo Moreira",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enzoomoreira/tab-audio-recorder.git"
  },
  "bugs": {
    "url": "https://github.com/enzoomoreira/tab-audio-recorder/issues"
  },
  "homepage": "https://github.com/enzoomoreira/tab-audio-recorder#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/selenium-webdriver": "^4.35.6",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "geckodriver": "^6.1.0",
    "happy-dom": "^20.9.0",
    "jest-webextension-mock": "^4.1.1",
    "prettier": "^3.8.3",
    "selenium-webdriver": "^4.44.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^4.1.7",
    "web-ext": "^10.2.0"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7"
  }
}
